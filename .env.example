# SENTINEL-AI Configuration File
# Copy this file to .env and fill in your API keys and settings
# All sensitive values should be configured here, never hardcode them in the application

# Application Settings
DEBUG=True
PROJECT_NAME=SENTINEL-AI
VERSION=1.0.0
API_V1_PREFIX=/api/v1
API_PORT=8000

# ════════════════════════════════════════════════════════════════════════════════
# THREAT INTELLIGENCE API KEYS
# ════════════════════════════════════════════════════════════════════════════════
# These APIs are used for security threat analysis and intelligence gathering

# VirusTotal - Malware and threat detection
# Get your key at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
# AbuseIPDB - IP reputation and abuse scoring
# Get your key at: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Shodan - Network infrastructure and vulnerability discovery
# Get your key at: https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key_here

# Hybrid Analysis - Sandbox malware analysis
# Get your key at: https://www.hybrid-analysis.com/manage-api
HYBRIDANALYSIS_API_KEY=your_hybridanalysis_api_key_here

# URLScan.io - URL scanning and phishing detection
# Get your key at: https://urlscan.io/user/profile/
URLSCAN_API_KEY=your_urlscan_api_key_here

# Enable or disable external threat intelligence APIs
# Set to 'false' to run in local-only mode (uses only heuristic analysis)
EXTERNAL_APIS_ENABLED=true

# ════════════════════════════════════════════════════════════════════════════════
# GEMINI API CONFIGURATION (for AI-powered threat analysis and reports)
# ════════════════════════════════════════════════════════════════════════════════
# Get your keys at: https://aistudio.google.com/app/apikeys

# Primary Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Alternative: Multiple keys (comma-separated) for load balancing
GEMINI_API_KEYS=

# Numbered Gemini API keys (supports up to 20 keys for higher capacity)
# Use these to distribute API calls across multiple keys
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
GEMINI_API_KEY_8=
GEMINI_API_KEY_9=
GEMINI_API_KEY_10=
GEMINI_API_KEY_11=
GEMINI_API_KEY_12=
GEMINI_API_KEY_13=
GEMINI_API_KEY_14=
GEMINI_API_KEY_15=
GEMINI_API_KEY_16=
GEMINI_API_KEY_17=
GEMINI_API_KEY_18=
GEMINI_API_KEY_19=
GEMINI_API_KEY_20=

# Alternative Google API keys naming convention (also supported)
GOOGLE_API_KEYS=
GOOGLE_API_KEY_1=
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GOOGLE_API_KEY_4=
GOOGLE_API_KEY_5=

# Gemini Model Configuration
# Available models: gemini-1.5-pro, gemini-1.5-pro-latest, gemini-1.5-flash, gemini-2.5-flash, gemini-pro
GEMINI_MODEL_CANDIDATES=gemini-1.5-flash,gemini-2.5-flash,gemini-1.5-pro

# Gemini Report Generation Limits
GEMINI_DAILY_REPORT_LIMIT=80
GEMINI_HOURLY_REPORT_LIMIT=20

# Only generate reports for executives (extended analysis)
GEMINI_EXECUTIVE_ONLY=false

# Gemini Performance and Reliability Tuning
GEMINI_QUOTA_COOLDOWN_SECONDS=900
GEMINI_ANALYSIS_CACHE_TTL_SECONDS=1800
GEMINI_ANALYSIS_CACHE_SIZE=64
GEMINI_MIN_REQUEST_INTERVAL=2.0
GEMINI_MAX_ATTEMPTS=3
GEMINI_CIRCUIT_THRESHOLD=5
GEMINI_CIRCUIT_OPEN_SECONDS=60
GEMINI_REQUEST_TIMEOUT_SECONDS=45

# ════════════════════════════════════════════════════════════════════════════════
# OPENAI API CONFIGURATION (for future AI integration)
# ════════════════════════════════════════════════════════════════════════════════
# Get your API key at: https://platform.openai.com/api-keys

# Primary OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# Multiple OpenAI keys (comma-separated) for load balancing
OPENAI_API_KEYS=

# Numbered OpenAI API keys
OPENAI_API_KEY_1=
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=
OPENAI_API_KEY_4=
OPENAI_API_KEY_5=

# OpenAI Configuration
OPENAI_MODEL=gpt-4-turbo
OPENAI_ORG_ID=

# ════════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

DATABASE_URL=sqlite:///./sentinel.db
REDIS_URL=redis://localhost:6379

# ════════════════════════════════════════════════════════════════════════════════
# SECURITY SETTINGS
# ════════════════════════════════════════════════════════════════════════════════

SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ════════════════════════════════════════════════════════════════════════════════
# CORS AND HOST SETTINGS
# ════════════════════════════════════════════════════════════════════════════════

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5000,http://127.0.0.1:3000,http://127.0.0.1:8080,http://127.0.0.1:5000

# ════════════════════════════════════════════════════════════════════════════════
# EMAIL SETTINGS (Optional - for security alerts and notifications)
# ════════════════════════════════════════════════════════════════════════════════

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password_here
FROM_EMAIL=alerts@sentinel-ai.com
ALERT_EMAIL=security-team@example.com
CLIENT_REGISTRATION_ALERT_EMAILS=sec-lead@example.com,soc@example.com

# ════════════════════════════════════════════════════════════════════════════════
# ADMIN AND INFRASTRUCTURE SETTINGS
# ════════════════════════════════════════════════════════════════════════════════

# Client-safe dashboard mode (recommended true for client-facing portal)
SENTINEL_CLIENT_SAFE_DASHBOARD_MODE=true

# Admin bypass key for protected management endpoints
# Send as header: X-Sentinel-Admin-Bypass: <value>
SENTINEL_ADMIN_BYPASS_KEY=replace-with-long-random-secret

# Treat these hosts/IPs as admin infrastructure (excluded from client inventory)
ADMIN_INFRA_HOSTNAMES=kali,kali-linux-vbox
ADMIN_INFRA_IPS=127.0.0.1

# Client master password and admin email
MASTER_CLIENT_PASSWORD=changeme-please
ADMIN_EMAIL=raviranbir007@gmail.com

# ════════════════════════════════════════════════════════════════════════════════
# RATE LIMITING & CACHING
# ════════════════════════════════════════════════════════════════════════════════

RATE_LIMIT_PER_MINUTE=60
API_CACHE_TTL=300

# ════════════════════════════════════════════════════════════════════════════════
# SENTINEL API GOVERNANCE & PERFORMANCE CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════

# Maximum concurrent API calls to external providers
SENTINEL_API_MAX_CONCURRENT_CALLS=12

# Queue wait timeout for API calls (seconds)
SENTINEL_API_QUEUE_WAIT_TIMEOUT=2.0

# Number of failures before opening circuit breaker
SENTINEL_API_FAILURE_THRESHOLD=4

# Circuit breaker cooldown time (seconds)
SENTINEL_API_CIRCUIT_COOLDOWN_SECONDS=90

# Daily budget for API calls
SENTINEL_API_BUDGET_DAILY=5000

# ════════════════════════════════════════════════════════════════════════════════
# SENTINEL ADAPTIVE HARDENING & MONITORING
# ════════════════════════════════════════════════════════════════════════════════

# Enable startup monitors for system health checks
SENTINEL_ENABLE_STARTUP_MONITORS=true

# Escalate to external APIs when high-threat indicators detected
SENTINEL_ESCALATE_EXTERNAL_API_ON_THREAT=true

# Network monitoring configuration
SENTINEL_ENABLE_NETWORK_MONITORING=true
SENTINEL_MONITOR_STATUS_INTERVAL=3600
SENTINEL_NETWORK_SCAN_COOLDOWN=600
SENTINEL_NETWORK_POLL_INTERVAL=15
SENTINEL_SCAN_LOCAL_TARGETS=false

# Browser and activity monitoring
SENTINEL_PROMPT_COOLDOWN=900
SENTINEL_URL_REVISIT_COOLDOWN=60
SENTINEL_BROWSER_HISTORY_BATCH=1000
SENTINEL_BROWSER_HISTORY_PATHS=

# Download monitoring
SENTINEL_DOWNLOAD_POLL_INTERVAL=15
SENTINEL_DOWNLOAD_SETTLE_SECONDS=20
SENTINEL_DOWNLOAD_MAX_FILE_SIZE=157286400

# Duplicate detection
SENTINEL_PROMPT_DUPLICATE_SUPPRESS_SECONDS=5

# Advanced threat detection thresholds (JSON format)
SENTINEL_DETECTOR_THRESHOLD_PROFILES_JSON=
SENTINEL_DETECTOR_CALIBRATION_JSON=

# ════════════════════════════════════════════════════════════════════════════════
# DEFENSE DECISION CONTROLS
# ════════════════════════════════════════════════════════════════════════════════

# Minimum severity to automatically block (low, medium, high, critical)
SENTINEL_AUTO_BLOCK_MIN_SEVERITY=high

# Require manual approval for blocking actions
SENTINEL_ENABLE_MANUAL_APPROVAL=true

# Minimum confidence score for manual review (0.0 - 1.0)
SENTINEL_MANUAL_REVIEW_MIN_CONFIDENCE=0.65
