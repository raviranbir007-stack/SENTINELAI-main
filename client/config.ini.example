[client]
# Scan / heartbeat intervals (seconds)
scan_interval=300
heartbeat_interval=60

[server]
url=http://localhost:8000
api_key=

[apis]
# Required / recommended threat-intel APIs
virustotal=
abuseipdb=
urlscan=
otx=
ipqualityscore=

# Optional enrichment APIs
shodan=
hybrid_analysis=

[email]
scan_local_thunderbird=true
poll_interval=60
imap_host=
imap_port=993
imap_user=
imap_pass=
pop3_host=
pop3_port=995
pop3_user=
pop3_pass=

[vulnerability]
scan_interval_hours=6
full_scan_on_start=true

[dns]
poll_interval=5
use_scapy=false

[network]
poll_interval=10

[process]
poll_interval=5

[behavior]
poll_interval=5
