# SENTINEL-AI Configuration File
# Copy this file to .env and fill in your API keys


# API Keys for Threat Intelligence Services
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
SHODAN_API_KEY=your_shodan_api_key_here
HYBRIDANALYSIS_API_KEY=your_hybridanalysis_api_key_here
URLSCAN_API_KEY=your_urlscan_api_key_here

# Gemini API for AI-powered analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///./sentinel.db
REDIS_URL=redis://localhost:6379

# Security Settings
SECRET_KEY=your-secret-key-here-change-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
DEBUG=True
API_PORT=8000
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5000,http://127.0.0.1:3000,http://127.0.0.1:8080,http://127.0.0.1:5000

# Email Settings (Optional - for alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password_here
FROM_EMAIL=alerts@sentinel-ai.com
ALERT_EMAIL=security-team@example.com
CLIENT_REGISTRATION_ALERT_EMAILS=sec-lead@example.com,soc@example.com

# Client-safe dashboard/API mode (recommended true for client-facing portal)
SENTINEL_CLIENT_SAFE_DASHBOARD_MODE=true
# Optional bypass header key for admin-only backend calls to protected management endpoints
# Send as: X-Sentinel-Admin-Bypass: <value>
SENTINEL_ADMIN_BYPASS_KEY=replace-with-long-random-secret

# Treat matching hosts as admin/server infrastructure (exclude from client inventory view)
ADMIN_INFRA_HOSTNAMES=kali,kali-linux-vbox
ADMIN_INFRA_IPS=127.0.0.1

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
API_CACHE_TTL=300
